# AetherCast Environment Variables

# Open-Meteo API (free, no key required)
NEXT_PUBLIC_OPEN_METEO_BASE=https://api.open-meteo.com

# MapLibre (optional - uses free OSM tiles by default)
NEXT_PUBLIC_MAPTILER_KEY=

# Premium Weather API (optional)
METEOMATICS_API_KEY=

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# AI Chat (optional)
OPENAI_API_KEY=
