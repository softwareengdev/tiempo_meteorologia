{
  "ci": {
    "collect": {
      "url": [
        "https://tiempo-meteorologia.pages.dev/",
        "https://tiempo-meteorologia.pages.dev/ciudades",
        "https://tiempo-meteorologia.pages.dev/location/madrid",
        "https://tiempo-meteorologia.pages.dev/comparador",
        "https://tiempo-meteorologia.pages.dev/sobre"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],

        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "interactive": ["warn", { "maxNumericValue": 3500 }],

        "uses-text-compression": "error",
        "uses-responsive-images": "warn",
        "uses-rel-preconnect": "warn",
        "font-display": "warn",
        "color-contrast": "error",
        "image-alt": "error",
        "meta-description": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "robots-txt": "warn",
        "canonical": "warn",

        "csp-xss": "off",
        "unused-javascript": "off",
        "unused-css-rules": "off",
        "uses-long-cache-ttl": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
